# Nidus configuration. Copy to `.env` and fill in your values.
# All variables use the NIDUS_ prefix.

# --- Chat model (OpenAI-compatible) ---
# Works with OpenAI, Doubao/Ark, DeepSeek, Ollama, vLLM, etc.
NIDUS_LLM_BASE_URL=https://api.openai.com/v1
NIDUS_LLM_API_KEY=sk-your-key-here
NIDUS_LLM_MODEL=gpt-4o-mini
NIDUS_LLM_TEMPERATURE=0.0
# Stability controls (important for smaller open models that can otherwise
# degenerate into repetition loops): cap output length, penalise repetition,
# and time out slow calls.
NIDUS_LLM_MAX_TOKENS=1024
NIDUS_LLM_FREQUENCY_PENALTY=0.3
NIDUS_LLM_REQUEST_TIMEOUT=60

# --- Embeddings (OpenAI-compatible) ---
# Leave BASE_URL / API_KEY unset to reuse the chat credentials above.
# NIDUS_EMBED_BASE_URL=
# NIDUS_EMBED_API_KEY=
NIDUS_EMBED_MODEL=text-embedding-3-small
# IMPORTANT: embed_dim MUST match your embedding model's output size.
#   text-embedding-3-small = 1536, text-embedding-3-large = 3072
NIDUS_EMBED_DIM=1536

# --- Qdrant vector store ---
# Embedded mode (default): leave NIDUS_QDRANT_URL unset; data persists on disk.
NIDUS_QDRANT_PATH=./.nidus/qdrant
NIDUS_QDRANT_COLLECTION=nidus
# Server mode: set the URL (and API key for Qdrant Cloud).
# NIDUS_QDRANT_URL=http://localhost:6333
# NIDUS_QDRANT_API_KEY=

# --- Retrieval / ingestion ---
NIDUS_CHUNK_SIZE=1000
NIDUS_CHUNK_OVERLAP=150
NIDUS_RETRIEVER_K=4

# --- Agent graph ---
NIDUS_MAX_RETRIES=2
NIDUS_ENABLE_DIRECT_ANSWER=true

# --- API server ---
NIDUS_HOST=127.0.0.1
NIDUS_PORT=8000

# Example: Doubao / Volcengine Ark
# NIDUS_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# NIDUS_LLM_API_KEY=your-ark-key
# NIDUS_LLM_MODEL=doubao-pro-32k

# Example: Ollama (fully local)
# NIDUS_LLM_BASE_URL=http://localhost:11434/v1
# NIDUS_LLM_API_KEY=ollama
# NIDUS_LLM_MODEL=llama3.1
# NIDUS_EMBED_MODEL=nomic-embed-text
# NIDUS_EMBED_DIM=768
